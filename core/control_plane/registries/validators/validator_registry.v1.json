{
  "$schema": "urn:watchtower:schema:artifacts:registries:validator-registry:v1",
  "id": "registry.validators",
  "title": "Validator Registry",
  "status": "active",
  "validators": [
    {
      "id": "validator.control_plane.acceptance_contract",
      "title": "Acceptance Contract Validator",
      "description": "Validates machine-readable acceptance contract artifacts.",
      "status": "active",
      "engine": "json_schema",
      "artifact_kind": "acceptance_contract",
      "applies_to": [
        "core/control_plane/contracts/acceptance/**"
      ],
      "schema_ids": [
        "urn:watchtower:schema:artifacts:contracts:acceptance-contract:v1"
      ]
    },
    {
      "id": "validator.control_plane.traceability_index",
      "title": "Traceability Index Validator",
      "description": "Validates unified machine-readable traceability index artifacts.",
      "status": "active",
      "engine": "json_schema",
      "artifact_kind": "traceability_index",
      "applies_to": [
        "core/control_plane/indexes/traceability/**"
      ],
      "schema_ids": [
        "urn:watchtower:schema:artifacts:indexes:traceability-index:v1"
      ]
    },
    {
      "id": "validator.control_plane.validation_evidence",
      "title": "Validation Evidence Validator",
      "description": "Validates durable validation-evidence ledger artifacts.",
      "status": "active",
      "engine": "json_schema",
      "artifact_kind": "validation_evidence",
      "applies_to": [
        "core/control_plane/ledgers/validation_evidence/**"
      ],
      "schema_ids": [
        "urn:watchtower:schema:artifacts:ledgers:validation-evidence:v1"
      ]
    },
    {
      "id": "validator.trace.acceptance_reconciliation",
      "title": "Acceptance Reconciliation Validator",
      "description": "Validates alignment across PRD acceptance IDs, acceptance contracts, validation evidence, validator references, and traceability for one traced initiative.",
      "status": "active",
      "engine": "python",
      "artifact_kind": "acceptance_reconciliation",
      "applies_to": [
        "docs/planning/prds/**",
        "core/control_plane/contracts/acceptance/**",
        "core/control_plane/ledgers/validation_evidence/**",
        "core/control_plane/indexes/traceability/**"
      ],
      "notes": "Used by the watchtower-core validate acceptance command."
    },
    {
