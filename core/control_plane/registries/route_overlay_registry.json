        "Commit Closeout"
      ],
      "dominant_route_retention_mode": "strongest_compatible",
      "exclude_attached_task_types_from_base_scoring": true,
      "retain_dominant_compatible_route": true,
      "minimum_route_score": 12,
      "notes": "Treats explicit commit intent as a retained closeout companion instead of allowing it to displace the dominant substantive route."
