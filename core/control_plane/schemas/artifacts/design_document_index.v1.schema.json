{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:indexes:design-document-index:v1",
  "title": "Design Document Index",
  "description": "Machine-readable tracking index for feature designs and implementation plans stored under docs/design/.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:indexes:design-document-index:v1",
      "description": "Schema identifier for this design-document index artifact."
    },
    "id": {
      "type": "string",
      "const": "index.design_documents",
      "description": "Stable identifier for the design-document index artifact."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title for the design-document index."
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "entries": {
      "type": "array",
      "description": "Lookup and tracking records for design documents.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/designDocumentEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "docPath": {
      "type": "string",
      "pattern": "^docs/design/(features|implementation)/.+\\.md$"
    },
    "dateString": {
      "type": "string",
      "format": "date"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "designDocumentEntry": {
      "type": "object",
      "required": [
        "document_id",
        "family",
        "title",
        "summary",
        "status",
        "doc_path",
        "last_synced"
      ],
      "properties": {
        "document_id": {
          "$ref": "#/$defs/idPattern",
          "description": "Stable machine-usable identifier for the design document entry."
        },
        "family": {
          "type": "string",
          "enum": [
            "feature_design",
            "implementation_plan"
          ],
          "description": "Design document family."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable design document title."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Concise description of the design document."
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "doc_path": {
          "$ref": "#/$defs/docPath",
          "description": "Repository-relative path to the design document."
        },
        "last_synced": {
          "$ref": "#/$defs/dateString",
          "description": "Last meaningful content update date for the design document."
        },
        "source_paths": {
          "$ref": "#/$defs/stringList",
          "description": "Driving source surfaces such as feature designs or PRDs."
        },
        "related_paths": {
          "$ref": "#/$defs/stringList",
          "description": "Optional related repository paths strongly associated with the design document."
        },
        "tags": {
          "$ref": "#/$defs/stringList",
          "description": "Optional retrieval-oriented tags."
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Optional short tracking note."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "family": {
                "const": "implementation_plan"
              }
            },
            "required": [
              "family"
            ]
          },
          "then": {
            "required": [
              "source_paths"
            ]
          }
        }
      ]
    }
  }
}
