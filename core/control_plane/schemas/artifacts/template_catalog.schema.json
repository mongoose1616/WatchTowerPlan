{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:template-catalog:v1",
  "title": "Template Catalog",
  "description": "Schema for the reusable-core template catalog covering governed template assets, section requirements, and authoring guidance.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:template-catalog:v1"
    },
    "id": {
      "const": "registry.template_catalog"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/lifecycleStatus"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/templateEntry"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "lifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "authorshipMode": {
      "type": "string",
      "enum": [
        "authored",
        "rendered"
      ]
    },
    "guidanceMode": {
      "type": "string",
      "enum": [
        "required",
        "advisory",
        "none"
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "boundedStringList": {
      "allOf": [
        {
          "$ref": "#/$defs/stringList"
        },
        {
          "minItems": 1
        }
      ]
    },
    "sectionCardinalityRule": {
      "type": "object",
      "required": [
        "section_id",
        "min_occurs",
        "max_occurs"
      ],
      "properties": {
        "section_id": {
          "type": "string",
          "minLength": 1
        },
        "min_occurs": {
          "type": "integer",
          "minimum": 0
        },
        "max_occurs": {
          "type": "integer",
          "minimum": 1
        },
        "mutually_exclusive_group": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "llmGuidance": {
      "type": "object",
      "required": [
        "authoring_goal"
      ],
      "properties": {
        "authoring_goal": {
          "type": "string",
          "minLength": 1
        },
        "hard_requirements": {
          "$ref": "#/$defs/stringList"
        },
        "advisory_notes": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "templateEntry": {
      "type": "object",
      "required": [
        "template_id",
        "entry_status",
        "authorship_mode",
        "template_path",
        "required_section_ids",
        "optional_section_ids",
        "section_order",
        "llm_guidance_mode",
        "allowed_roots"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "family_id": {
          "type": "string",
          "minLength": 1
        },
        "surface_id": {
          "type": "string",
          "minLength": 1
        },
        "entry_status": {
          "$ref": "#/$defs/lifecycleStatus"
        },
        "authorship_mode": {
          "$ref": "#/$defs/authorshipMode"
        },
        "template_path": {
          "type": "string",
          "minLength": 1
        },
        "front_matter_schema_id": {
          "type": "string",
          "minLength": 1
        },
        "required_section_ids": {
          "$ref": "#/$defs/boundedStringList"
        },
        "optional_section_ids": {
          "$ref": "#/$defs/stringList"
        },
        "section_order": {
          "$ref": "#/$defs/boundedStringList"
        },
        "prohibited_section_ids": {
          "$ref": "#/$defs/stringList"
        },
        "section_cardinality_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sectionCardinalityRule"
          }
        },
        "section_spec_schema_id": {
          "type": "string",
          "minLength": 1
        },
        "llm_guidance": {
          "$ref": "#/$defs/llmGuidance"
        },
        "llm_guidance_mode": {
          "$ref": "#/$defs/guidanceMode"
        },
        "operator_notes": {
          "type": "string",
          "minLength": 1
        },
        "required_rendered_surface_ids": {
          "$ref": "#/$defs/stringList"
        },
        "allowed_roots": {
          "$ref": "#/$defs/boundedStringList"
        }
      },
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "family_id"
          ]
        },
        {
          "required": [
            "surface_id"
          ]
        }
      ]
    }
  }
}
