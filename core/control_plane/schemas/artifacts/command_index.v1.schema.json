{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:indexes:command-index:v1",
  "title": "Command Index",
  "description": "Machine-readable lookup index for repository commands, their command pages, and their implementation surfaces.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "workspace",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:indexes:command-index:v1",
      "description": "Schema identifier for this command index artifact."
    },
    "id": {
      "type": "string",
      "const": "index.commands",
      "description": "Stable identifier for the command index artifact."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title for the command index."
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "workspace": {
      "type": "string",
      "minLength": 1,
      "description": "Stable workspace label for the indexed command family."
    },
    "entries": {
      "type": "array",
      "description": "Lookup records for commands and subcommands.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/commandEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "pathString": {
      "type": "string",
      "minLength": 1
    },
    "docPath": {
      "type": "string",
      "pattern": "^docs/commands/.+\\.md$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commandEntry": {
      "type": "object",
      "required": [
        "command_id",
        "command",
        "summary",
        "kind",
        "status",
        "workspace",
        "doc_path",
        "synopsis"
      ],
      "properties": {
        "command_id": {
          "$ref": "#/$defs/idPattern",
          "description": "Stable machine-usable identifier for the command entry."
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "description": "Literal command invocation label."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Concise description of what the command does."
        },
        "kind": {
          "type": "string",
          "enum": [
            "root_command",
            "subcommand"
          ],
          "description": "Whether the entry is a root command or a subcommand."
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "workspace": {
          "type": "string",
          "minLength": 1,
          "description": "Stable workspace label for the command entry."
        },
        "doc_path": {
          "$ref": "#/$defs/docPath",
          "description": "Repository-relative path to the human-readable command page."
        },
        "synopsis": {
          "type": "string",
          "minLength": 1,
          "description": "Short usage form for quick lookup."
        },
        "implementation_path": {
          "$ref": "#/$defs/pathString",
          "description": "Repository-relative implementation surface for the command."
        },
        "package_entrypoint": {
          "type": "string",
          "minLength": 1,
          "description": "Import-style package entrypoint when one exists."
        },
        "parent_command_id": {
          "$ref": "#/$defs/idPattern",
          "description": "Stable parent command identifier for subcommands."
        },
        "aliases": {
          "$ref": "#/$defs/stringList",
          "description": "Optional alternate lookup terms for the command."
        },
        "tags": {
          "$ref": "#/$defs/stringList",
          "description": "Optional command lookup tags."
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Optional short command note."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "subcommand"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "parent_command_id"
            ]
          }
        }
      ]
    }
  }
}
