{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:registries:benchmark-suite-registry:v1",
  "title": "Benchmark Suite Registry",
  "description": "Schema for authored benchmark suite registry artifacts that declare reusable benchmark command sets.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "suites"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:registries:benchmark-suite-registry:v1"
    },
    "id": {
      "type": "string",
      "const": "registry.benchmark_suites"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/suiteRecord"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "argvList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commandRecord": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "argv"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/idPattern"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "argv": {
          "$ref": "#/$defs/argvList"
        },
        "measured_runs_override": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "suiteRecord": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "status",
        "working_directory",
        "warmup_runs",
        "measured_runs",
        "commands"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/idPattern"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "working_directory": {
          "$ref": "#/$defs/relativePath"
        },
        "warmup_runs": {
          "type": "integer",
          "minimum": 0
        },
        "measured_runs": {
          "type": "integer",
          "minimum": 1
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/commandRecord"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
