{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:indexes:foundation-index:v1",
  "title": "Foundation Index",
  "description": "Machine-readable lookup index for governed foundation documents stored under docs/foundations/.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:indexes:foundation-index:v1"
    },
    "id": {
      "type": "string",
      "const": "index.foundations"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/lifecycleStatus"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/foundationEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "lifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "authority": {
      "type": "string",
      "enum": [
        "authoritative",
        "supporting",
        "reference",
        "historical"
      ]
    },
    "audience": {
      "type": "string",
      "enum": [
        "shared",
        "maintainers",
        "contributors"
      ]
    },
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "docPath": {
      "type": "string",
      "pattern": "^docs/foundations/.+\\.md$"
    },
    "referenceDocPathList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^docs/references/.+\\.md$"
      }
    },
    "markdownPathList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(docs|workflows)/.+\\.md$"
      }
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "urlList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^https?://.+$"
      }
    },
    "foundationEntry": {
      "type": "object",
      "required": [
        "foundation_id",
        "title",
        "summary",
        "status",
        "audience",
        "authority",
        "doc_path",
        "updated_at",
        "uses_internal_references",
        "uses_external_references"
      ],
      "properties": {
        "foundation_id": {
          "$ref": "#/$defs/idPattern"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycleStatus"
        },
        "audience": {
          "$ref": "#/$defs/audience"
        },
        "authority": {
          "$ref": "#/$defs/authority"
        },
        "doc_path": {
          "$ref": "#/$defs/docPath"
        },
        "updated_at": {
          "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
        },
        "uses_internal_references": {
          "type": "boolean"
        },
        "uses_external_references": {
          "type": "boolean"
        },
        "related_paths": {
          "$ref": "#/$defs/stringList"
        },
        "reference_doc_paths": {
          "$ref": "#/$defs/referenceDocPathList"
        },
        "internal_reference_paths": {
          "$ref": "#/$defs/stringList"
        },
        "external_reference_urls": {
          "$ref": "#/$defs/urlList"
        },
        "cited_by_paths": {
          "$ref": "#/$defs/markdownPathList"
        },
        "applied_by_paths": {
          "$ref": "#/$defs/markdownPathList"
        },
        "aliases": {
          "$ref": "#/$defs/stringList"
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "uses_external_references": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "external_reference_urls"
            ]
          }
        }
      ]
    }
  }
}
