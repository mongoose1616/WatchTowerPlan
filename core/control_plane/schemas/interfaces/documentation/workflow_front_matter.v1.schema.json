{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:documentation:workflow-front-matter:v1",
  "title": "Workflow Front Matter",
  "description": "Parsed front matter profile for workflow documents that adopt governed metadata.",
  "allOf": [
    {
      "$ref": "urn:watchtower:schema:interfaces:documentation:front-matter-base:v1"
    },
    {
      "type": "object",
      "required": [
        "id",
        "title",
        "summary",
        "type",
        "status",
        "owner",
        "updated",
        "audience"
      ],
      "properties": {
        "type": {
          "const": "workflow"
        }
      }
    }
  ]
}
