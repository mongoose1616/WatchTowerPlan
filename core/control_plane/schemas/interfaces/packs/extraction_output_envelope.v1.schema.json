{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:extraction-output-envelope:v1",
  "title": "Extraction Output Envelope",
  "description": "Structured extraction workflow output for one pack-owned work item before promotion into reusable knowledge.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "summary",
    "status",
    "pack_id",
    "work_item_id",
    "trace_id",
    "source_note_id",
    "workflow_run_id",
    "extraction_method",
    "created_at",
    "observations",
    "candidate_knowledge"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:extraction-output-envelope:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "pack_id": {
      "$ref": "#/$defs/idPattern"
    },
    "work_item_id": {
      "$ref": "#/$defs/idPattern"
    },
    "trace_id": {
      "$ref": "#/$defs/idPattern"
    },
    "source_note_id": {
      "$ref": "#/$defs/idPattern"
    },
    "artifact_manifest_id": {
      "$ref": "#/$defs/idPattern"
    },
    "workflow_run_id": {
      "$ref": "#/$defs/idPattern"
    },
    "extraction_method": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/observationEntry"
      }
    },
    "candidate_knowledge": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidateKnowledgeEntry"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "superseded",
        "archived"
      ]
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "idList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/idPattern"
      }
    },
    "observationEntry": {
      "type": "object",
      "required": [
        "observation_id",
        "summary"
      ],
      "properties": {
        "observation_id": {
          "$ref": "#/$defs/idPattern"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "candidateKnowledgeEntry": {
      "type": "object",
      "required": [
        "candidate_id",
        "title",
        "summary",
        "knowledge_family"
      ],
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/idPattern"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "knowledge_family": {
          "type": "string",
          "minLength": 1
        },
        "evidence_artifact_ids": {
          "$ref": "#/$defs/idList"
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    }
  }
}
