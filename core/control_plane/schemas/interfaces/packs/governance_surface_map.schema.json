{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:governance-surface-map:v1",
  "title": "Governance Surface Map",
  "description": "Schema for one pack-owned governance surface map over non-artifact governed surfaces.",
  "type": "object",
  "required": [
    "$schema",
    "surface_name",
    "contract_version",
    "description",
    "updated_at",
    "surfaces"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:governance-surface-map:v1"
    },
    "surface_name": {
      "const": "governance_surface_map"
    },
    "contract_version": {
      "const": "v1"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surfaceDeclaration"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "surfaceDeclaration": {
      "type": "object",
      "required": [
        "surface_name",
        "surface_kind",
        "path",
        "authority",
        "visibility"
      ],
      "properties": {
        "surface_name": {
          "type": "string",
          "minLength": 1
        },
        "surface_kind": {
          "type": "string",
          "enum": [
            "pack_settings",
            "schema_collection",
            "path_pattern_registry",
            "status_registry",
            "actor_registry",
            "workflow_catalog",
            "routing_table",
            "workflow_module_root"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "authority": {
          "type": "string",
          "enum": ["authoritative", "derived"]
        },
        "visibility": {
          "type": "string",
          "enum": ["hidden", "user", "mixed"]
        },
        "rebuildable": {
          "type": "boolean"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "builder": {
          "type": "string",
          "minLength": 1
        },
        "source_surface": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
