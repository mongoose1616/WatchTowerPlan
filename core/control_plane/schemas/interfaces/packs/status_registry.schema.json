{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:status-registry:v1",
  "title": "Status Registry",
  "description": "Schema for one pack-owned global status registry with per-family allowed subsets.",
  "type": "object",
  "required": [
    "$schema",
    "surface_name",
    "contract_version",
    "description",
    "updated_at",
    "statuses"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:status-registry:v1"
    },
    "surface_name": {
      "const": "status_registry"
    },
    "contract_version": {
      "const": "v1"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/statusEntry"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "statusEntry": {
      "type": "object",
      "required": [
        "value",
        "entry_status",
        "summary"
      ],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "entry_status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "allowed_families": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
