{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:knowledge-index:v1",
  "title": "Knowledge Index",
  "description": "Pack-local index over promoted reusable knowledge items and their promotion lineage.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "pack_id",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:knowledge-index:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "pack_id": {
      "$ref": "#/$defs/idPattern"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/knowledgeEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    },
    "knowledgeStatus": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "superseded",
        "archived"
      ]
    },
    "repoPath": {
      "type": "string",
      "pattern": "^(?!/).+"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "idList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/idPattern"
      }
    },
    "knowledgeEntry": {
      "type": "object",
      "required": [
        "knowledge_id",
        "title",
        "summary",
        "status",
        "knowledge_family",
        "canonical_path",
        "promotion_record_id",
        "extraction_output_id",
        "promoted_at",
        "source_work_item_ids"
      ],
      "properties": {
        "knowledge_id": {
          "$ref": "#/$defs/idPattern"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/knowledgeStatus"
        },
        "knowledge_family": {
          "type": "string",
          "minLength": 1
        },
        "canonical_path": {
          "$ref": "#/$defs/repoPath"
        },
        "promotion_record_id": {
          "$ref": "#/$defs/idPattern"
        },
        "extraction_output_id": {
          "$ref": "#/$defs/idPattern"
        },
        "promoted_at": {
          "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
        },
        "source_work_item_ids": {
          "$ref": "#/$defs/idList"
        },
        "trace_id": {
          "$ref": "#/$defs/idPattern"
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    }
  }
}
