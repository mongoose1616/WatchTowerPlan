{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:path-pattern-registry:v1",
  "title": "Path Pattern Registry",
  "description": "Schema for one pack-owned path-pattern registry that maps artifact families to canonical user, hidden, and rendered paths.",
  "type": "object",
  "required": [
    "$schema",
    "surface_name",
    "contract_version",
    "description",
    "updated_at",
    "patterns"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:path-pattern-registry:v1"
    },
    "surface_name": {
      "const": "path_pattern_registry"
    },
    "contract_version": {
      "const": "v1"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/patternEntry"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "patternEntry": {
      "type": "object",
      "required": [
        "family_name",
        "path_kind",
        "path_pattern",
        "entity_shape",
        "visibility",
        "authoritative"
      ],
      "properties": {
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "path_kind": {
          "type": "string",
          "enum": ["user_visible", "hidden_authoritative", "rendered_view"]
        },
        "path_pattern": {
          "type": "string",
          "minLength": 1
        },
        "entity_shape": {
          "type": "string",
          "enum": ["file", "directory", "stream"]
        },
        "visibility": {
          "type": "string",
          "enum": ["hidden", "user", "mixed"]
        },
        "authoritative": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
