{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:promoted-knowledge:v1",
  "title": "Promoted Knowledge",
  "description": "Reviewed reusable knowledge item promoted from structured pack extraction output.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "summary",
    "status",
    "pack_id",
    "trace_id",
    "knowledge_family",
    "content_markdown",
    "promoted_at",
    "promotion_record_id",
    "extraction_output_id",
    "source_work_item_ids"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:promoted-knowledge:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "pack_id": {
      "$ref": "#/$defs/idPattern"
    },
    "trace_id": {
      "$ref": "#/$defs/idPattern"
    },
    "knowledge_family": {
      "type": "string",
      "minLength": 1
    },
    "content_markdown": {
      "type": "string",
      "minLength": 1
    },
    "promoted_at": {
      "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
    },
    "promotion_record_id": {
      "$ref": "#/$defs/idPattern"
    },
    "extraction_output_id": {
      "$ref": "#/$defs/idPattern"
    },
    "source_work_item_ids": {
      "$ref": "#/$defs/idList"
    },
    "tags": {
      "$ref": "#/$defs/stringList"
    },
    "related_knowledge_ids": {
      "$ref": "#/$defs/idList"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "superseded",
        "archived"
      ]
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "idList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/idPattern"
      }
    }
  }
}
