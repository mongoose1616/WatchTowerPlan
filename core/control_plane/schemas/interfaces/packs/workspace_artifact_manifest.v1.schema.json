{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:workspace-artifact-manifest:v1",
  "title": "Workspace Artifact Manifest",
  "description": "Metadata-only manifest of pack-local workspace artifacts associated with one work item.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "pack_id",
    "work_item_id",
    "root_path",
    "updated_at",
    "artifacts"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:workspace-artifact-manifest:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "pack_id": {
      "$ref": "#/$defs/idPattern"
    },
    "work_item_id": {
      "$ref": "#/$defs/idPattern"
    },
    "root_path": {
      "$ref": "#/$defs/repoPath"
    },
    "updated_at": {
      "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifactEntry"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "archived"
      ]
    },
    "repoPath": {
      "type": "string",
      "pattern": "^(?!/).+"
    },
    "mediaType": {
      "type": "string",
      "pattern": "^[A-Za-z0-9.+-]+\\/[A-Za-z0-9.+-]+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifactEntry": {
      "type": "object",
      "required": [
        "artifact_id",
        "relative_path",
        "media_type",
        "role"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/idPattern"
        },
        "relative_path": {
          "$ref": "#/$defs/repoPath"
        },
        "media_type": {
          "$ref": "#/$defs/mediaType"
        },
        "role": {
          "type": "string",
          "enum": [
            "note",
            "attachment",
            "evidence",
            "binary",
            "text",
            "archive",
            "workflow_output",
            "other"
          ]
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "captured_at": {
          "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
        },
        "labels": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    }
  }
}
