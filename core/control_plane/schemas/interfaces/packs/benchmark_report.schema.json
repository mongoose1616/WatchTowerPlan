{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:benchmark-report:v1",
  "title": "Benchmark Report",
  "description": "Generic pack-owned benchmark capture for baseline, task-slice, and closeout performance evidence.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "trace_id",
    "initiative_slug",
    "benchmark_kind",
    "captured_at",
    "commands"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:benchmark-report:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "trace_id": {
      "$ref": "#/$defs/idPattern"
    },
    "initiative_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "benchmark_kind": {
      "type": "string",
      "enum": [
        "baseline",
        "task_slice",
        "closeout"
      ]
    },
    "task_id": {
      "$ref": "#/$defs/idPattern"
    },
    "captured_at": {
      "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
    },
    "baseline_reference": {
      "$ref": "#/$defs/relativePath"
    },
    "benchmark_contract": {
      "$ref": "#/$defs/benchmarkContract"
    },
    "commands": {
      "$ref": "#/$defs/commandMap"
    },
    "ranked_hotspot_families": {
      "$ref": "#/$defs/hotspotFamilyList"
    },
    "service_microbenchmarks": {
      "$ref": "#/$defs/microbenchmarkMap"
    },
    "startup_microbenchmarks": {
      "$ref": "#/$defs/microbenchmarkMap"
    },
    "additional_signals": {
      "$ref": "#/$defs/numericMetricMap"
    },
    "follow_up_decision": {
      "$ref": "#/$defs/followUpDecision"
    },
    "closeout_decision": {
      "$ref": "#/$defs/closeoutDecision"
    },
    "notes": {
      "$ref": "#/$defs/stringList"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "archived"
      ]
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/).+"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "numberList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number"
      }
    },
    "envMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "numericMetricMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number"
      }
    },
    "benchmarkContract": {
      "type": "object",
      "properties": {
        "runs_per_mode": {
          "type": "integer",
          "minimum": 1
        },
        "telemetry_on_env": {
          "$ref": "#/$defs/envMap"
        },
        "telemetry_off_env": {
          "$ref": "#/$defs/envMap"
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "nestedOperationEntry": {
      "type": "object",
      "required": [
        "operation_kind",
        "operation_name",
        "median_duration_ms"
      ],
      "properties": {
        "operation_kind": {
          "type": "string",
          "minLength": 1
        },
        "operation_name": {
          "type": "string",
          "minLength": 1
        },
        "median_duration_ms": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "commandEntry": {
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "telemetry_on_runs_ms": {
          "$ref": "#/$defs/numberList"
        },
        "telemetry_off_runs_ms": {
          "$ref": "#/$defs/numberList"
        },
        "median_ms_telemetry_on": {
          "type": "number"
        },
        "median_ms_telemetry_off": {
          "type": "number"
        },
        "delta_ms": {
          "type": "number"
        },
        "ratio_on_over_off": {
          "type": "number"
        },
        "top_nested_operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nestedOperationEntry"
          }
        },
        "observation": {
          "type": "string",
          "minLength": 1
        },
        "baseline_median_ms": {
          "type": "number"
        },
        "current_median_ms": {
          "type": "number"
        },
        "improvement_ms": {
          "type": "number"
        },
        "improvement_percent": {
          "type": "number"
        },
        "baseline_telemetry_on_median_ms": {
          "type": "number"
        },
        "final_telemetry_on_median_ms": {
          "type": "number"
        },
        "telemetry_on_improvement_ms": {
          "type": "number"
        },
        "telemetry_on_improvement_percent": {
          "type": "number"
        },
        "baseline_telemetry_off_median_ms": {
          "type": "number"
        },
        "final_telemetry_off_median_ms": {
          "type": "number"
        },
        "telemetry_off_improvement_ms": {
          "type": "number"
        },
        "telemetry_off_improvement_percent": {
          "type": "number"
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "commandMap": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/commandEntry"
      }
    },
    "hotspotFamilyEntry": {
      "type": "object",
      "required": [
        "rank",
        "task_id",
        "reason"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "task_id": {
          "$ref": "#/$defs/idPattern"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "hotspotFamilyList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hotspotFamilyEntry"
      }
    },
    "beforeAfterMeasurement": {
      "type": "object",
      "required": [
        "before_ms",
        "after_ms"
      ],
      "properties": {
        "before_ms": {
          "type": "number"
        },
        "after_ms": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "microbenchmarkMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/beforeAfterMeasurement"
      }
    },
    "followUpDecision": {
      "type": "object",
      "required": [
        "reason"
      ],
      "properties": {
        "next_task_id": {
          "$ref": "#/$defs/idPattern"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "closeoutDecision": {
      "type": "object",
      "required": [
        "accepted",
        "reason"
      ],
      "properties": {
        "accepted": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
