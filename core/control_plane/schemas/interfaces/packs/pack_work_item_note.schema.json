{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:packs:pack-work-item-note:v1",
  "title": "Pack Work Item Note",
  "description": "Generic operator-authored note interface for one pack-owned work item.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "summary",
    "status",
    "pack_id",
    "work_item_id",
    "work_item_type",
    "lifecycle_stage",
    "updated_at"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:interfaces:packs:pack-work-item-note:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "pack_id": {
      "$ref": "#/$defs/idPattern"
    },
    "work_item_id": {
      "$ref": "#/$defs/idPattern"
    },
    "work_item_type": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_stage": {
      "$ref": "#/$defs/lifecycleStage"
    },
    "trace_id": {
      "$ref": "#/$defs/idPattern"
    },
    "artifact_manifest_id": {
      "$ref": "#/$defs/idPattern"
    },
    "updated_at": {
      "$ref": "urn:watchtower:schema:common:timestamps:utc-timestamp:v1"
    },
    "tags": {
      "$ref": "#/$defs/stringList"
    },
    "source_paths": {
      "$ref": "#/$defs/pathList"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "archived"
      ]
    },
    "lifecycleStage": {
      "type": "string",
      "enum": [
        "inbox",
        "triaged",
        "active",
        "completed",
        "archived"
      ]
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pathList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/).+"
      }
    }
  }
}
