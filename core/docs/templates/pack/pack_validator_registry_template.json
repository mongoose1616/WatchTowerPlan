{
  "$schema": "urn:watchtower:schema:artifacts:registries:validator-registry:v1",
  "id": "registry.validators",
  "title": "<pack_title> Pack Validators",
  "status": "active",
  "validators": [
    {
      "id": "validator.<pack_slug>.<note_slug>",
      "title": "<pack_title> Note Validator",
      "description": "Pack-local validator for the starter note artifact.",
      "status": "active",
      "engine": "json_schema",
      "artifact_kind": "<note_slug>",
      "applies_to": [
        "<pack_root>/.wt/work_items/<note_slug>.json"
      ],
      "schema_ids": [
        "urn:watchtower:schema:interfaces:packs:<schema_slug>:v1"
      ]
    },
    {
      "id": "validator.<pack_slug>.validation_suite_registry",
      "title": "<pack_title> Validation Suite Registry Validator",
      "description": "Validates the pack-owned validation suite registry that extends the shared core validation suite surface.",
      "status": "active",
      "engine": "json_schema",
      "artifact_kind": "validation_suite_registry",
      "applies_to": [
        "<pack_root>/.wt/registries/validation_suite_registry.json"
      ],
      "schema_ids": [
        "urn:watchtower:schema:artifacts:registries:validation-suite-registry:v1"
      ]
    },
    {
      "id": "validator.<pack_slug>.workflow_metadata_registry",
      "title": "<pack_title> Workflow Metadata Registry Validator",
      "description": "Validates the pack-owned workflow metadata registry that extends the shared core workflow metadata surface.",
      "status": "active",
      "engine": "json_schema",
      "artifact_kind": "workflow_metadata_registry",
      "applies_to": [
        "<pack_root>/.wt/registries/workflow_metadata_registry.json"
      ],
      "schema_ids": [
        "urn:watchtower:schema:artifacts:registries:workflow-metadata-registry:v1"
      ]
    }
  ]
}
