#!/usr/bin/env bash
# Lightweight pre-push gate: mypy + ruff only (~0.2 s).
# Full test suites are run manually via verify.sh before pushing.
set -euo pipefail

if [[ "${WATCHTOWER_SKIP_VERIFY:-0}" == "1" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root/core/python"

failed=0

printf '[mypy]\n'
if ! uv run mypy src; then
  failed=1
fi

printf '[ruff]\n'
if ! uv run ruff check src tests/unit tests/integration; then
  failed=1
fi

if [[ "$failed" -ne 0 ]]; then
  printf '\npre-push: lint/type check failed — push blocked.\n' >&2
  exit 1
fi
