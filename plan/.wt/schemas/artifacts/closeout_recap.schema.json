{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:closeout-recap:v1",
  "title": "Closeout Recap",
  "description": "Schema for one initiative-local closeout shell or structured closeout recap.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "initiative_id",
    "title",
    "status",
    "updated_at",
    "expected_outcome",
    "acceptance_ids",
    "evidence_ids",
    "follow_up_handling",
    "promotion_review_required",
    "terminal_state_options"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:closeout-recap:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "initiative_id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "active",
        "completed"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "expected_outcome": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_ids": {
      "$ref": "#/$defs/nonEmptyIdList"
    },
    "evidence_ids": {
      "$ref": "#/$defs/nonEmptyIdList"
    },
    "follow_up_handling": {
      "type": "string",
      "minLength": 1
    },
    "promotion_review_required": {
      "type": "boolean"
    },
    "terminal_state_options": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "completed",
          "superseded",
          "cancelled"
        ]
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "nonEmptyIdList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/idPattern"
      }
    }
  }
}
