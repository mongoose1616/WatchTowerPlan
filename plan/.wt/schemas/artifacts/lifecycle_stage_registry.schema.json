{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:lifecycle-stage-registry:v1",
  "title": "Lifecycle Stage Registry",
  "description": "Schema for the plan-pack lifecycle-stage registry covering controlled lifecycle vocabulary separate from status values.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:lifecycle-stage-registry:v1"
    },
    "id": {
      "const": "registry.lifecycle_stage"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lifecycleStageEntry"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "currentPhase": {
      "type": "string",
      "enum": [
        "implementation_planning",
        "execution",
        "closeout",
        "closed"
      ]
    },
    "lifecycleStageEntry": {
      "type": "object",
      "required": [
        "stage_id",
        "value",
        "entry_status",
        "summary",
        "current_phase",
        "terminal"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "entry_status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "deprecated"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "current_phase": {
          "$ref": "#/$defs/currentPhase"
        },
        "terminal": {
          "type": "boolean"
        },
        "allowed_families": {
          "$ref": "#/$defs/stringList"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
