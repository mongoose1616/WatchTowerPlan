{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:promotion-index:v1",
  "title": "Plan Promotion Index",
  "description": "Schema for the pack-level promotion index built from initiative-local guidance-promotion records.",
  "type": "object",
  "required": ["$schema", "id", "title", "status", "updated_at", "entries"],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:promotion-index:v1"
    },
    "id": {
      "const": "index.promotions"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promotionEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pathList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/).+"
      }
    },
    "promotionEntry": {
      "type": "object",
      "required": [
        "promotion_id",
        "initiative_id",
        "trace_id",
        "initiative_title",
        "title",
        "status",
        "initiative_root",
        "candidate_count",
        "candidate_paths",
        "target_families",
        "review_paths",
        "updated_at"
      ],
      "properties": {
        "promotion_id": {
          "$ref": "#/$defs/idPattern"
        },
        "initiative_id": {
          "$ref": "#/$defs/idPattern"
        },
        "project_id": {
          "$ref": "#/$defs/idPattern"
        },
        "trace_id": {
          "$ref": "#/$defs/idPattern"
        },
        "initiative_title": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["planned", "candidate", "promoted", "rejected"]
        },
        "initiative_root": {
          "type": "string",
          "pattern": "^plan/(initiatives|projects/.+/initiatives)/.+$"
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 1
        },
        "candidate_paths": {
          "$ref": "#/$defs/pathList"
        },
        "target_paths": {
          "$ref": "#/$defs/pathList"
        },
        "target_families": {
          "$ref": "#/$defs/stringList"
        },
        "review_paths": {
          "$ref": "#/$defs/stringList"
        },
        "approval_state": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "$ref": "#/$defs/stringList"
        },
        "provenance_expectations": {
          "$ref": "#/$defs/stringList"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
