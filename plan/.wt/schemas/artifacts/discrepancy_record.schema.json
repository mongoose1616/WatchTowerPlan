{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:discrepancy-record:v1",
  "title": "Discrepancy Record",
  "description": "Schema for one initiative-local discrepancy record.",
  "type": "object",
  "required": [
    "$schema",
    "discrepancy_id",
    "initiative_id",
    "category",
    "severity",
    "gate_effect",
    "status",
    "summary",
    "source_paths",
    "detected_at",
    "updated_at"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:discrepancy-record:v1"
    },
    "discrepancy_id": {
      "$ref": "#/$defs/idPattern"
    },
    "initiative_id": {
      "$ref": "#/$defs/idPattern"
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "gate_effect": {
      "type": "string",
      "enum": [
        "none",
        "readiness",
        "execution",
        "all_progress"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resolved"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/).+"
      }
    },
    "resolution_owner": {
      "type": "string",
      "minLength": 1
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    }
  }
}
