{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:relation-type-registry:v1",
  "title": "Relation Type Registry",
  "description": "Schema for the plan-pack relation type registry covering controlled cross-artifact relation names.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "title",
    "status",
    "entries"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:relation-type-registry:v1"
    },
    "id": {
      "const": "registry.relation_type"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relationTypeEntry"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cardinality": {
      "type": "string",
      "enum": [
        "one_to_one",
        "one_to_many",
        "many_to_one",
        "many_to_many"
      ]
    },
    "relationTypeEntry": {
      "type": "object",
      "required": [
        "relation_type_id",
        "canonical_name",
        "entry_status",
        "summary",
        "directional",
        "source_families",
        "target_families"
      ],
      "properties": {
        "relation_type_id": {
          "$ref": "#/$defs/idPattern"
        },
        "canonical_name": {
          "type": "string",
          "minLength": 1
        },
        "entry_status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "deprecated"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "directional": {
          "type": "boolean"
        },
        "inverse_name": {
          "type": "string",
          "minLength": 1
        },
        "source_families": {
          "$ref": "#/$defs/stringList"
        },
        "target_families": {
          "$ref": "#/$defs/stringList"
        },
        "cardinality": {
          "$ref": "#/$defs/cardinality"
        },
        "allowed_path_fields": {
          "$ref": "#/$defs/stringList"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
