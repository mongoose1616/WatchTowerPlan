{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:guidance-promotion-record:v1",
  "title": "Guidance Promotion Record",
  "description": "Schema for one initiative-local promotion shell or guidance-promotion record.",
  "type": "object",
  "required": [
    "$schema",
    "id",
    "initiative_id",
    "trace_id",
    "title",
    "status",
    "approval_state",
    "review_refs",
    "evidence_refs",
    "updated_at",
    "candidates"
  ],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:guidance-promotion-record:v1"
    },
    "id": {
      "$ref": "#/$defs/idPattern"
    },
    "initiative_id": {
      "$ref": "#/$defs/idPattern"
    },
    "trace_id": {
      "$ref": "#/$defs/idPattern"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "candidate",
        "promoted",
        "rejected"
      ]
    },
    "approval_state": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    },
    "approver_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/idPattern"
      }
    },
    "review_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/idPattern"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidateRecord"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "candidateRecord": {
      "type": "object",
      "required": [
        "candidate_path",
        "source_artifact_kind",
        "target_family",
        "target_path",
        "review_path",
        "provenance_expectation",
        "mirror_update_mode"
      ],
      "properties": {
        "candidate_path": {
          "type": "string",
          "pattern": "^(?!/).+"
        },
        "source_artifact_kind": {
          "type": "string",
          "minLength": 1
        },
        "target_family": {
          "type": "string",
          "minLength": 1
        },
        "target_path": {
          "type": "string",
          "pattern": "^(plan|core)/docs/.+\\.md$"
        },
        "review_path": {
          "type": "string",
          "minLength": 1
        },
        "provenance_expectation": {
          "type": "string",
          "minLength": 1
        },
        "mirror_update_mode": {
          "type": "string",
          "enum": [
            "none",
            "same_change_set",
            "generated_copy",
            "promotion_fan_out"
          ]
        },
        "mirror_target_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(plan|core)/docs/.+\\.md$"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
