{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:review-index:v1",
  "title": "Plan Review Index",
  "description": "Schema for the plan-workspace review index built from initiative review state and promotion approval state.",
  "type": "object",
  "required": ["$schema", "id", "title", "status", "updated_at", "entries"],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:review-index:v1"
    },
    "id": {
      "const": "index.reviews"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "stringList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewEntry": {
      "type": "object",
      "required": [
        "review_subject_id",
        "subject_kind",
        "initiative_id",
        "trace_id",
        "initiative_title",
        "title",
        "review_state",
        "review_refs",
        "evidence_refs",
        "updated_at"
      ],
      "properties": {
        "review_subject_id": {
          "$ref": "#/$defs/idPattern"
        },
        "subject_kind": {
          "type": "string",
          "enum": ["initiative", "promotion"]
        },
        "initiative_id": {
          "$ref": "#/$defs/idPattern"
        },
        "project_id": {
          "$ref": "#/$defs/idPattern"
        },
        "trace_id": {
          "$ref": "#/$defs/idPattern"
        },
        "initiative_title": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "review_state": {
          "type": "string",
          "minLength": 1
        },
        "review_refs": {
          "$ref": "#/$defs/stringList"
        },
        "evidence_refs": {
          "$ref": "#/$defs/stringList"
        },
        "lifecycle_stage": {
          "type": "string",
          "minLength": 1
        },
        "ready_for_execution": {
          "type": "boolean"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
