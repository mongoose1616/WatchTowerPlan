{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:artifacts:plan:evidence-index:v1",
  "title": "Plan Evidence Index",
  "description": "Schema for the plan-workspace evidence index built from initiative-local validation bundles.",
  "type": "object",
  "required": ["$schema", "id", "title", "status", "updated_at", "entries"],
  "properties": {
    "$schema": {
      "const": "urn:watchtower:schema:artifacts:plan:evidence-index:v1"
    },
    "id": {
      "const": "index.evidence"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "idPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pathList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/).+"
      }
    },
    "evidenceEntry": {
      "type": "object",
      "required": [
        "evidence_id",
        "initiative_id",
        "trace_id",
        "initiative_title",
        "title",
        "status",
        "initiative_root",
        "entry_count",
        "acceptance_labels",
        "validation_types",
        "owners",
        "target_phases",
        "expected_output_paths",
        "updated_at"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/idPattern"
        },
        "initiative_id": {
          "$ref": "#/$defs/idPattern"
        },
        "project_id": {
          "$ref": "#/$defs/idPattern"
        },
        "trace_id": {
          "$ref": "#/$defs/idPattern"
        },
        "initiative_title": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["planned", "active", "completed"]
        },
        "initiative_root": {
          "type": "string",
          "pattern": "^plan/(initiatives|projects/.+/initiatives)/.+$"
        },
        "entry_count": {
          "type": "integer",
          "minimum": 1
        },
        "acceptance_labels": {
          "$ref": "#/$defs/stringList"
        },
        "validation_types": {
          "$ref": "#/$defs/stringList"
        },
        "owners": {
          "$ref": "#/$defs/stringList"
        },
        "target_phases": {
          "$ref": "#/$defs/stringList"
        },
        "expected_output_paths": {
          "$ref": "#/$defs/pathList"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
