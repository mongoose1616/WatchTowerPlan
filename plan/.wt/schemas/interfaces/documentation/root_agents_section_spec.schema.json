{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:root-agents-section-spec:v1",
  "title": "Root AGENTS Section Spec",
  "description": "Schema for the normalized section projection used to validate the governed AGENTS.md template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.root.agents"
    },
    "required_section_ids": {
      "const": [
        "role",
        "scope",
        "routing_or_behavior_differences",
        "local_instructions",
        "exclusions_or_constraints"
      ]
    },
    "optional_section_ids": {
      "const": [
        "do",
        "do_not"
      ]
    },
    "section_order": {
      "const": [
        "role",
        "scope",
        "routing_or_behavior_differences",
        "local_instructions",
        "exclusions_or_constraints",
        "do",
        "do_not"
      ]
    },
    "template_heading_ids": {
      "const": [
        "role",
        "scope",
        "routing_or_behavior_differences",
        "local_instructions",
        "exclusions_or_constraints",
        "do",
        "do_not"
      ]
    }
  },
  "additionalProperties": false
}
