{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:pattern-section-spec:v1",
  "title": "Pattern Section Spec",
  "description": "Schema for the normalized section projection used to validate the governed pattern template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.guidance.pattern"
    },
    "required_section_ids": {
      "const": [
        "scenario",
        "recommended_structure",
        "boundaries_or_constraints",
        "usage_notes"
      ]
    },
    "optional_section_ids": {
      "const": [
        "illustrative_example"
      ]
    },
    "section_order": {
      "const": [
        "scenario",
        "recommended_structure",
        "boundaries_or_constraints",
        "usage_notes",
        "illustrative_example"
      ]
    },
    "template_heading_ids": {
      "const": [
        "scenario",
        "recommended_structure",
        "boundaries_or_constraints",
        "usage_notes",
        "illustrative_example"
      ]
    }
  },
  "additionalProperties": false
}
