{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:root-readme-section-spec:v1",
  "title": "Root README Section Spec",
  "description": "Schema for the normalized section projection used to validate the governed root README template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.root.readme"
    },
    "required_section_ids": {
      "const": [
        "root_purpose",
        "contents_or_subtrees",
        "navigation_hints",
        "related_machine_surfaces"
      ]
    },
    "optional_section_ids": {
      "const": []
    },
    "section_order": {
      "const": [
        "root_purpose",
        "contents_or_subtrees",
        "navigation_hints",
        "related_machine_surfaces"
      ]
    },
    "template_heading_ids": {
      "const": [
        "root_purpose",
        "contents_or_subtrees",
        "navigation_hints",
        "related_machine_surfaces"
      ]
    }
  },
  "additionalProperties": false
}
