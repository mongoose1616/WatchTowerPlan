{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:project-repositories-section-spec:v1",
  "title": "Project Repositories Section Spec",
  "description": "Schema for the normalized section projection used to validate the rendered project repositories template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids",
    "required_rendered_surface_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.rendered.project.repositories"
    },
    "required_section_ids": {
      "const": [
        "repository_role_summary",
        "repository_locations",
        "ownership_or_access_notes",
        "implementation_vs_planning_boundary",
        "active_flags"
      ]
    },
    "optional_section_ids": {
      "const": []
    },
    "section_order": {
      "const": [
        "repository_role_summary",
        "repository_locations",
        "ownership_or_access_notes",
        "implementation_vs_planning_boundary",
        "active_flags"
      ]
    },
    "template_heading_ids": {
      "const": [
        "repository_role_summary",
        "repository_locations",
        "ownership_or_access_notes",
        "implementation_vs_planning_boundary",
        "active_flags"
      ]
    },
    "required_rendered_surface_ids": {
      "const": [
        "rendered.project.repositories"
      ]
    }
  },
  "additionalProperties": false
}
