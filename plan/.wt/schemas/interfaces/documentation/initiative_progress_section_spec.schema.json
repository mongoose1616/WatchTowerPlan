{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:initiative-progress-section-spec:v1",
  "title": "Initiative Progress Section Spec",
  "description": "Schema for the normalized section projection used to validate the rendered initiative progress template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids",
    "required_rendered_surface_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.rendered.initiative.progress"
    },
    "required_section_ids": {
      "const": [
        "current_status",
        "recent_events_or_changes",
        "active_tasks",
        "blockers",
        "next_actions",
        "evidence_or_validation_state"
      ]
    },
    "optional_section_ids": {
      "const": []
    },
    "section_order": {
      "const": [
        "current_status",
        "recent_events_or_changes",
        "active_tasks",
        "blockers",
        "next_actions",
        "evidence_or_validation_state"
      ]
    },
    "template_heading_ids": {
      "const": [
        "current_status",
        "recent_events_or_changes",
        "active_tasks",
        "blockers",
        "next_actions",
        "evidence_or_validation_state"
      ]
    },
    "required_rendered_surface_ids": {
      "const": [
        "rendered.initiative.progress"
      ]
    }
  },
  "additionalProperties": false
}
