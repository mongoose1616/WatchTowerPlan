{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:plan-overview-section-spec:v1",
  "title": "Plan Overview Section Spec",
  "description": "Schema for the normalized section projection used to validate the rendered plan overview template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids",
    "required_rendered_surface_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.rendered.plan_overview"
    },
    "required_section_ids": {
      "const": [
        "plan_domain_summary",
        "active_pack_wide_initiatives",
        "active_project_initiatives",
        "blocked_or_attention_needed_items",
        "recent_completions_or_changes",
        "navigation_links"
      ]
    },
    "optional_section_ids": {
      "const": []
    },
    "section_order": {
      "const": [
        "plan_domain_summary",
        "active_pack_wide_initiatives",
        "active_project_initiatives",
        "blocked_or_attention_needed_items",
        "recent_completions_or_changes",
        "navigation_links"
      ]
    },
    "template_heading_ids": {
      "const": [
        "plan_domain_summary",
        "active_pack_wide_initiatives",
        "active_project_initiatives",
        "blocked_or_attention_needed_items",
        "recent_completions_or_changes",
        "navigation_links"
      ]
    },
    "required_rendered_surface_ids": {
      "const": [
        "rendered.plan.overview"
      ]
    }
  },
  "additionalProperties": false
}
