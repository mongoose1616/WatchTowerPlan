{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:project-surface-section-spec:v1",
  "title": "Project Surface Section Spec",
  "description": "Schema for the normalized section projection used to validate the rendered project.md template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids",
    "required_rendered_surface_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.rendered.project.project"
    },
    "required_section_ids": {
      "const": [
        "project_identity",
        "purpose_and_scope",
        "current_state",
        "linked_initiatives",
        "linked_repositories",
        "key_references_or_docs"
      ]
    },
    "optional_section_ids": {
      "const": []
    },
    "section_order": {
      "const": [
        "project_identity",
        "purpose_and_scope",
        "current_state",
        "linked_initiatives",
        "linked_repositories",
        "key_references_or_docs"
      ]
    },
    "template_heading_ids": {
      "const": [
        "project_identity",
        "purpose_and_scope",
        "current_state",
        "linked_initiatives",
        "linked_repositories",
        "key_references_or_docs"
      ]
    },
    "required_rendered_surface_ids": {
      "const": [
        "rendered.project.project"
      ]
    }
  },
  "additionalProperties": false
}
