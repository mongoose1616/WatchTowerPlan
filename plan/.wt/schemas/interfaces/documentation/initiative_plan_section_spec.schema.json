{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:initiative-plan-section-spec:v1",
  "title": "Initiative Plan Section Spec",
  "description": "Schema for the normalized section projection used to validate the rendered initiative plan template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids",
    "required_rendered_surface_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.rendered.initiative.plan"
    },
    "required_section_ids": {
      "const": [
        "initiative_identity",
        "scope_and_non_goals",
        "objectives",
        "planned_slices_or_workstreams",
        "dependencies_and_risks",
        "validation_or_completion_gates",
        "linked_outputs"
      ]
    },
    "optional_section_ids": {
      "const": []
    },
    "section_order": {
      "const": [
        "initiative_identity",
        "scope_and_non_goals",
        "objectives",
        "planned_slices_or_workstreams",
        "dependencies_and_risks",
        "validation_or_completion_gates",
        "linked_outputs"
      ]
    },
    "template_heading_ids": {
      "const": [
        "initiative_identity",
        "scope_and_non_goals",
        "objectives",
        "planned_slices_or_workstreams",
        "dependencies_and_risks",
        "validation_or_completion_gates",
        "linked_outputs"
      ]
    },
    "required_rendered_surface_ids": {
      "const": [
        "rendered.initiative.plan"
      ]
    }
  },
  "additionalProperties": false
}
