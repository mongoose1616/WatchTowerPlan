{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:decision-record-section-spec:v1",
  "title": "Decision Record Section Spec",
  "description": "Schema for the normalized section projection used to validate the governed decision-record template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.guidance.decision_record"
    },
    "required_section_ids": {
      "const": [
        "context",
        "decision",
        "consequences",
        "current_status_or_supersession_notes"
      ]
    },
    "optional_section_ids": {
      "const": []
    },
    "section_order": {
      "const": [
        "context",
        "decision",
        "consequences",
        "current_status_or_supersession_notes"
      ]
    },
    "template_heading_ids": {
      "const": [
        "context",
        "decision",
        "consequences",
        "current_status_or_supersession_notes"
      ]
    }
  },
  "additionalProperties": false
}
