{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:watchtower:schema:interfaces:plan:documentation:reference-section-spec:v1",
  "title": "Reference Section Spec",
  "description": "Schema for the normalized section projection used to validate the governed reference template.",
  "type": "object",
  "required": [
    "template_id",
    "required_section_ids",
    "optional_section_ids",
    "section_order",
    "template_heading_ids"
  ],
  "properties": {
    "template_id": {
      "const": "template.plan.guidance.reference"
    },
    "required_section_ids": {
      "const": [
        "subject_summary",
        "usage_guidance",
        "provenance_or_source_notes",
        "related_surfaces"
      ]
    },
    "optional_section_ids": {
      "const": [
        "notes"
      ]
    },
    "section_order": {
      "const": [
        "subject_summary",
        "usage_guidance",
        "provenance_or_source_notes",
        "related_surfaces",
        "notes"
      ]
    },
    "template_heading_ids": {
      "const": [
        "subject_summary",
        "usage_guidance",
        "provenance_or_source_notes",
        "related_surfaces",
        "notes"
      ]
    }
  },
  "additionalProperties": false
}
