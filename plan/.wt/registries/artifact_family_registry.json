{
  "$schema": "urn:watchtower:schema:artifacts:plan:artifact-family-registry:v1",
  "id": "registry.artifact_family",
  "title": "Plan Artifact Family Registry",
  "status": "active",
  "entries": [
    {
      "family_id": "initiative_state",
      "entry_status": "active",
      "summary": "Authoritative current-state snapshot for one plan initiative package.",
      "canonical_schema_id": "urn:watchtower:schema:artifacts:plan:initiative-state:v1",
      "placement_roots": [
        "plan/initiatives/**/.wt/initiative.json",
        "plan/projects/**/initiatives/**/.wt/initiative.json"
      ],
      "status_field": "lifecycle_stage",
      "allowed_status_values": [
        "capture_incomplete",
        "ready_for_review",
        "ready_for_execution",
        "in_progress",
        "blocked",
        "closing",
        "completed",
        "superseded",
        "cancelled"
      ],
      "renderable": true,
      "rendered_companion_surface_ids": [
        "rendered.initiative.plan",
        "rendered.initiative.progress",
        "rendered.initiative.summary"
      ],
      "derived_index_ids": [
        "index.initiatives",
        "index.readiness",
        "index.plan_tasks",
        "index.plan_discrepancies",
        "index.promotions",
        "index.coordination"
      ],
      "visibility": "mixed"
    },
    {
      "family_id": "initiative_event_stream",
      "entry_status": "active",
      "summary": "Append-only initiative-local event history for lifecycle and approval changes.",
      "canonical_schema_id": "urn:watchtower:schema:artifacts:plan:initiative-event-stream:v1",
      "placement_roots": [
        "plan/initiatives/**/.wt/events/*.json",
        "plan/projects/**/initiatives/**/.wt/events/*.json"
      ],
      "status_field": "none",
      "renderable": false,
      "derived_index_ids": [
        "index.coordination"
      ],
      "visibility": "hidden"
    },
    {
      "family_id": "task_state",
      "entry_status": "active",
      "summary": "Authoritative current-state snapshot for one initiative-local task.",
      "canonical_schema_id": "urn:watchtower:schema:artifacts:plan:task-state:v1",
      "placement_roots": [
        "plan/initiatives/**/.wt/tasks/**/task.json",
        "plan/projects/**/initiatives/**/.wt/tasks/**/task.json"
      ],
      "status_field": "status",
      "allowed_status_values": [
        "planned",
        "ready",
        "in_progress",
        "in_review",
        "blocked",
        "completed",
        "cancelled"
      ],
      "renderable": true,
      "derived_index_ids": [
        "index.plan_tasks",
        "index.initiatives",
        "index.coordination"
      ],
      "visibility": "mixed"
    },
    {
      "family_id": "task_event_stream",
      "entry_status": "active",
      "summary": "Append-only task-local event history for task execution and review changes.",
      "canonical_schema_id": "urn:watchtower:schema:artifacts:plan:task-event-stream:v1",
      "placement_roots": [
        "plan/initiatives/**/.wt/tasks/**/events/*.json",
        "plan/projects/**/initiatives/**/.wt/tasks/**/events/*.json"
      ],
      "status_field": "none",
      "renderable": false,
      "derived_index_ids": [
        "index.plan_tasks",
        "index.coordination"
      ],
      "visibility": "hidden"
    },
    {
      "family_id": "deferred_item_record",
      "entry_status": "active",
      "summary": "Initiative-local deferred item contract for required unknowns that remain unresolved.",
      "canonical_schema_id": "urn:watchtower:schema:artifacts:plan:deferred-item-record:v1",
      "placement_roots": [
        "plan/initiatives/**/.wt/deferred/*.json",
        "plan/projects/**/initiatives/**/.wt/deferred/*.json"
      ],
      "status_field": "status",
      "allowed_status_values": [
        "open",
        "resolved"
      ],
      "renderable": true,
      "rendered_companion_surface_ids": [
        "rendered.initiative.plan",
        "rendered.initiative.summary"
      ],
      "derived_index_ids": [
        "index.initiatives",
        "index.readiness",
        "index.coordination"
      ],
      "visibility": "mixed"
    },
    {
      "family_id": "validation_bundle",
      "entry_status": "active",
