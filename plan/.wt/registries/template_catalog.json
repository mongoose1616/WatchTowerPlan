      "optional_section_ids": [
        "quick_start"
      ],
      "section_order": [
        "description",
        "quick_start",
        "paths",
        "notes"
      ],
      "llm_guidance": {
        "authoring_goal": "Create a thin navigation surface for one governed human root.",
        "hard_requirements": [
          "Keep the root focused on purpose, inventory, and routing instead of repeating deeper documentation.",
          "Point to machine-readable authority surfaces when that helps operators or agents find the real source of truth."
        ],
        "advisory_notes": [
          "Prefer one short paragraph for the description before the path table.",
          "Keep notes concise and operational."
        ]
      },
      "llm_guidance_mode": "advisory",
      "operator_notes": "Use for README.md files at governed human roots.",
      "allowed_roots": [
        ".",
        "core",
        "plan",
        "plan/docs",
        "plan/initiatives",
        "plan/projects",
        "plan/workflows"
      ]
