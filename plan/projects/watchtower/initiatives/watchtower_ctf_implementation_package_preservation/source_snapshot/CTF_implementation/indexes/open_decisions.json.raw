[
  {
    "decision_id": "decision.query_human_output_contract",
    "area": "query_runtime",
    "default": "curated queries support --format human|json|both with JSON as the default posture; human output is table-first plus one-line summaries where helpful, uses shared compact/standard/verbose presets, command-specific default row limits capped at roughly twenty, command-specific visible columns capped at six before expansion, explicit truncation and zero-result guidance, compact material trust/provenance cues, and treats status as the main operator-context command alongside a shared human structure for status, challenges, and sessions",
    "status": "locked_in_package",
    "upstream_dependency": "none_pack_owned",
    "affected_phases": [
      "phase.3",
      "phase.5"
    ]
  },
  {
    "decision_id": "decision.curated_relation_expansion_contract",
    "area": "query_runtime",
    "default": "curated family queries may expand relations only through one shared --expand-relations surface with one-hop default unless depth is explicit, separate expansion limits, a default per-root cap of five targets, shared relation/family/trust/review filter flags aligned with graph query, graph suggestions only on truncation, focus support limited to knowledge/artifacts/events/discrepancies, and one shared --sort contract with clear failures on unsupported fields",
    "status": "locked_in_package",
    "upstream_dependency": "none_pack_owned",
    "affected_phases": [
      "phase.3",
      "phase.5"
    ]
  },
  {
    "decision_id": "decision.graph_human_output_contract",
    "area": "graph_query",
    "default": "public graph query is core for agents but advanced for humans; human graph output defaults to depth-two capped traversal, root-summary plus relation-group presentation, repeated-node dedupe, inline provenance markers, root-plus-immediate-neighbor summaries, and named operator/provenance/retrieval/review modes as alias bundles over shared flags",
    "status": "locked_in_package",
    "upstream_dependency": "none_pack_owned",
    "affected_phases": [
      "phase.3",
      "phase.5"
    ]
  },
  {
    "decision_id": "decision.knowledge_human_output_contract",
    "area": "knowledge_retrieval",
    "default": "knowledge human output always labels result families, groups only when multiple families appear, uses the fixed human family order tactics/playbooks/tools/commands/references then everything else, keeps JSON ranking pure, distinguishes tactics strongly, exposes parent/support/tool cues for playbooks/commands/references, leaves filtered commands and references flatter by default with conditional subgrouping only when mixed-tool or mixed-target result sets appear, and reuses the same material-only why-this-matched explanation pattern across knowledge, commands, and references while clearly signaling included or excluded candidate material",
    "status": "locked_in_package",
    "upstream_dependency": "none_pack_owned",
    "affected_phases": [
      "phase.3",
      "phase.5"
    ]
  },
  {
    "decision_id": "decision.runtime_rollout_sequence",
    "area": "implementation_rollout",
    "default": "start runtime implementation with workflow metadata/docs plus the first machine-record bundle together, prove a thin real-CLI vertical slice on the actual pack root through challenge_intake -> challenge_metadata + notes_metadata + event_stream + artifact_index + query challenges + query artifacts using real schemas and validators, add unit tests plus CLI smoke tests immediately, then prove status, then blockers, then knowledge, ship graph after knowledge, run a short packaging/UX consolidation pass, and use a deliberately small/simple target for the first real challenge run; after consolidation choose the next capability by highest operator pain point with agent leverage as the secondary tie-break",
    "status": "locked_in_package",
    "upstream_dependency": "target_repo_integration",
    "affected_phases": [
      "phase.1",
      "phase.2",
      "phase.3"
    ]
  },
  {
    "decision_id": "decision.routing_contract",
